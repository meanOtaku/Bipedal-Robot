<mujoco model="autonomous_balance_biped">
  <option timestep="0.002" gravity="0 0 -9.81"/>
  
  <asset>
    <material name="white_print" rgba="0.95 0.95 0.95 1" specular="0.1" shininess="0.1"/>
    <material name="brass_screw" rgba="0.7 0.6 0.2 1" specular="1" shininess="0.8"/>
    <material name="dark_grey" rgba="0.2 0.2 0.2 1"/>
  </asset>

  <default>
    <geom contype="0" conaffinity="1"/>
    <joint damping="5.0" armature="0.05"/>
  </default>

  <worldbody>
    <light pos="0 0 3" dir="0 0 -1"/>
    <geom type="plane" size="5 5 0.1" rgba="0.15 0.15 0.15 1" contype="1" conaffinity="1"/>

    <body name="pelvis" pos="0 0 0.45">
      
      <freejoint/>
      <site name="imu_site" pos="0 0 0" size="0.02" rgba="1 0 0 1"/> 
      
      <geom type="box" size="0.08 0.18 0.06" material="dark_grey"/>

      <geom type="cylinder" size="0.035 0.005" pos="0.08 -0.185 -0.06" zaxis="0 1 0" material="white_print"/>
      <geom type="cylinder" size="0.035 0.005" pos="0.08 -0.115 -0.06" zaxis="0 1 0" material="white_print"/>
      <geom type="cylinder" size="0.035 0.005" pos="0.08 0.185 -0.06" zaxis="0 1 0" material="white_print"/>
      <geom type="cylinder" size="0.035 0.005" pos="0.08 0.115 -0.06" zaxis="0 1 0" material="white_print"/>

      <body name="right_thigh" pos="0.08 -0.15 -0.06">
        <joint name="right_hip" type="hinge" axis="0 1 0" range="-120 90"/>
        <geom type="cylinder" size="0.01 0.045" zaxis="0 1 0" material="brass_screw"/>

        <geom type="cylinder" size="0.035 0.025" pos="0 0 0" zaxis="0 1 0" material="white_print"/>
        <geom type="box" size="0.035 0.025 0.075" pos="0 0 -0.075" material="white_print"/>
        <geom type="cylinder" size="0.035 0.025" pos="0 0 -0.15" zaxis="0 1 0" material="white_print"/>
        
        <body name="right_calf" pos="0 0 -0.15">
          <joint name="right_knee" type="hinge" axis="0 1 0" range="-160 0"/>
          <geom type="cylinder" size="0.01 0.045" zaxis="0 1 0" material="brass_screw"/>

          <geom type="cylinder" size="0.035 0.005" pos="0 -0.035 0" zaxis="0 1 0" material="white_print"/>
          <geom type="box" size="0.035 0.005 0.075" pos="0 -0.035 -0.075" material="white_print"/>
          <geom type="cylinder" size="0.035 0.005" pos="0 -0.035 -0.15" zaxis="0 1 0" material="white_print"/>
          <geom type="cylinder" size="0.035 0.005" pos="0 0.035 0" zaxis="0 1 0" material="white_print"/>
          <geom type="box" size="0.035 0.005 0.075" pos="0 0.035 -0.075" material="white_print"/>
          <geom type="cylinder" size="0.035 0.005" pos="0 0.035 -0.15" zaxis="0 1 0" material="white_print"/>
          <geom type="box" size="0.01 0.03 0.075" pos="-0.025 0 -0.075" material="white_print"/>
          
          <body name="right_foot" pos="0 0 -0.15">
            <joint name="right_ankle" type="hinge" axis="0 1 0" range="-90 90"/>
            <geom type="cylinder" size="0.01 0.045" zaxis="0 1 0" material="brass_screw"/>
            
            <geom type="cylinder" size="0.035 0.025" pos="0 0 0" zaxis="0 1 0" material="white_print"/>
            <geom type="box" size="0.035 0.025 0.02" pos="0 0 -0.02" material="white_print"/>
            <geom type="box" size="0.08 0.025 0.01" pos="-0.04 0 -0.05" material="white_print"/>
          </body>
        </body>
      </body>

      <body name="left_thigh" pos="0.08 0.15 -0.06">
        <joint name="left_hip" type="hinge" axis="0 1 0" range="-120 90"/>
        <geom type="cylinder" size="0.01 0.045" zaxis="0 1 0" material="brass_screw"/>

        <geom type="cylinder" size="0.035 0.025" pos="0 0 0" zaxis="0 1 0" material="white_print"/>
        <geom type="box" size="0.035 0.025 0.075" pos="0 0 -0.075" material="white_print"/>
        <geom type="cylinder" size="0.035 0.025" pos="0 0 -0.15" zaxis="0 1 0" material="white_print"/>
        
        <body name="left_calf" pos="0 0 -0.15">
          <joint name="left_knee" type="hinge" axis="0 1 0" range="-160 0"/>
          <geom type="cylinder" size="0.01 0.045" zaxis="0 1 0" material="brass_screw"/>

          <geom type="cylinder" size="0.035 0.005" pos="0 -0.035 0" zaxis="0 1 0" material="white_print"/>
          <geom type="box" size="0.035 0.005 0.075" pos="0 -0.035 -0.075" material="white_print"/>
          <geom type="cylinder" size="0.035 0.005" pos="0 -0.035 -0.15" zaxis="0 1 0" material="white_print"/>
          <geom type="cylinder" size="0.035 0.005" pos="0 0.035 0" zaxis="0 1 0" material="white_print"/>
          <geom type="box" size="0.035 0.005 0.075" pos="0 0.035 -0.075" material="white_print"/>
          <geom type="cylinder" size="0.035 0.005" pos="0 0.035 -0.15" zaxis="0 1 0" material="white_print"/>
          <geom type="box" size="0.01 0.03 0.075" pos="-0.025 0 -0.075" material="white_print"/>
          
          <body name="left_foot" pos="0 0 -0.15">
            <joint name="left_ankle" type="hinge" axis="0 1 0" range="-90 90"/>
            <geom type="cylinder" size="0.01 0.045" zaxis="0 1 0" material="brass_screw"/>
            
            <geom type="cylinder" size="0.035 0.025" pos="0 0 0" zaxis="0 1 0" material="white_print"/>
            <geom type="box" size="0.035 0.025 0.02" pos="0 0 -0.02" material="white_print"/>
            <geom type="box" size="0.08 0.025 0.01" pos="-0.04 0 -0.05" material="white_print"/>
          </body>
        </body>
      </body>

    </body>
  </worldbody>

  <actuator>
    <position joint="right_hip" kp="800" name="pos_right_hip"/>
    <position joint="right_knee" kp="800" name="pos_right_knee"/>
    <position joint="right_ankle" kp="500" name="pos_right_ankle"/>
    
    <position joint="left_hip" kp="800" name="pos_left_hip"/>
    <position joint="left_knee" kp="800" name="pos_left_knee"/>
    <position joint="left_ankle" kp="500" name="pos_left_ankle"/>
  </actuator>

  <sensor>
    <framezaxis name="imu_tilt" objtype="site" objname="imu_site"/>
    <gyro name="imu_gyro" site="imu_site"/>
  </sensor>
</mujoco>
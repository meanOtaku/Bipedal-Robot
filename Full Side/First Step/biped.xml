<?xml version="1.0"?>
<mujoco model="colored_humanoid">

    <compiler angle="radian" inertiafromgeom="true"/>

    <option timestep="0.001"
            gravity="0 0 -9.81"
            solver="Newton"
            iterations="100"/>

    <default>
        <joint damping="20"
               armature="0.1"
               limited="true"/>

        <geom friction="2.0 0.1 0.1"/>

        <motor ctrllimited="true"
               ctrlrange="-1 1"/>
    </default>

    <worldbody>

        <geom name="ground"
              type="plane"
              pos="0 0 0"
              size="20 20 0.1"
              rgba="0.8 0.8 0.8 1"/>

        <!-- ================================================= -->
        <!-- TORSO -->
        <!-- ================================================= -->

        <body name="torso" pos="0 0 1.20">

            <freejoint name="root"/>

            <geom name="torso_geom"
                  type="box"
                  size="0.14 0.18 0.22"
                  mass="8"
                  rgba="0.2 0.2 0.9 1"/>

            <geom name="pelvis"
                  type="cylinder"
                  size="0.12 0.06"
                  pos="0 0 -0.22"
                  mass="10"
                  rgba="0.15 0.15 0.15 1"/>

            <!-- ================================================= -->
            <!-- LEFT LEG -->
            <!-- ================================================= -->

            <body name="left_hip_yaw_link"
                  pos="0 0.12 -0.22">

                <joint name="left_hip_yaw"
                       type="hinge"
                       axis="0 0 1"
                       range="-0.6 0.6"/>

                <geom type="cylinder"
                      size="0.035 0.04"
                      mass="0.2"
                      rgba="0 1 1 1"/>

                <body name="left_hip_roll_link"
                      pos="0 0 -0.06">

                    <joint name="left_hip_roll"
                           type="hinge"
                           axis="1 0 0"
                           range="-0.4 0.4"/>

                    <geom type="cylinder"
                          size="0.035 0.04"
                          quat="0.7071 0 0.7071 0"
                          mass="0.2"
                          rgba="1 0 1 1"/>

                    <body name="left_thigh_link"
                          pos="0 0 -0.06">

                        <joint name="left_hip_pitch"
                               type="hinge"
                               axis="0 1 0"
                               range="-1.5 0.8"/>

                        <geom type="cylinder"
                              size="0.045 0.06"
                              quat="0.7071 0.7071 0 0"
                              mass="0.2"
                              rgba="1 1 0 1"/>

                        <geom name="left_thigh"
                              type="capsule"
                              fromto="0 0 0 0 0 -0.40"
                              size="0.045"
                              mass="4"
                              rgba="0.85 0.2 0.2 1"/>

                        <body name="left_shin_link"
                              pos="0 0 -0.40">

                            <joint name="left_knee_pitch"
                                   type="hinge"
                                   axis="0 1 0"
                                   range="0 2.0"/>

                            <geom type="cylinder"
                                  size="0.04 0.05"
                                  quat="0.7071 0.7071 0 0"
                                  mass="0.2"
                                  rgba="1 0.5 0 1"/>

                            <geom name="left_shin"
                                  type="capsule"
                                  fromto="0 0 0 0 0 -0.40"
                                  size="0.04"
                                  mass="3"
                                  rgba="0.9 0.55 0.15 1"/>

                            <body name="left_ankle_pitch_link"
                                  pos="0 0 -0.40">

                                <joint name="left_ankle_pitch"
                                       type="hinge"
                                       axis="0 1 0"
                                       range="-0.8 0.6"/>

                                <geom type="cylinder"
                                      size="0.03 0.04"
                                      quat="0.7071 0.7071 0 0"
                                      mass="0.2"
                                      rgba="1 1 0 1"/>

                                <body name="left_foot_link"
                                      pos="0 0 -0.05">

                                    <joint name="left_ankle_roll"
                                           type="hinge"
                                           axis="1 0 0"
                                           range="-0.35 0.35"/>

                                    <geom type="cylinder"
                                          size="0.03 0.04"
                                          quat="0.7071 0 0.7071 0"
                                          mass="0.2"
                                          rgba="1 0 1 1"/>

                                    <geom name="left_foot"
                                          type="box"
                                          size="0.18 0.09 0.025"
                                          pos="0.06 0 -0.025"
                                          mass="1.5"
                                          rgba="0.2 0.8 0.2 1"/>

                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>

            <!-- ================================================= -->
            <!-- RIGHT LEG -->
            <!-- ================================================= -->

            <body name="right_hip_yaw_link"
                  pos="0 -0.12 -0.22">

                <joint name="right_hip_yaw"
                       type="hinge"
                       axis="0 0 1"
                       range="-0.6 0.6"/>

                <geom type="cylinder"
                      size="0.035 0.04"
                      mass="0.2"
                      rgba="0 1 1 1"/>

                <body name="right_hip_roll_link"
                      pos="0 0 -0.06">

                    <joint name="right_hip_roll"
                           type="hinge"
                           axis="1 0 0"
                           range="-0.4 0.4"/>

                    <geom type="cylinder"
                          size="0.035 0.04"
                          quat="0.7071 0 0.7071 0"
                          mass="0.2"
                          rgba="1 0 1 1"/>

                    <body name="right_thigh_link"
                          pos="0 0 -0.06">

                        <joint name="right_hip_pitch"
                               type="hinge"
                               axis="0 1 0"
                               range="-1.5 0.8"/>

                        <geom type="cylinder"
                              size="0.045 0.06"
                              quat="0.7071 0.7071 0 0"
                              mass="0.2"
                              rgba="1 1 0 1"/>

                        <geom name="right_thigh"
                              type="capsule"
                              fromto="0 0 0 0 0 -0.40"
                              size="0.045"
                              mass="4"
                              rgba="0.85 0.2 0.2 1"/>

                        <body name="right_shin_link"
                              pos="0 0 -0.40">

                            <joint name="right_knee_pitch"
                                   type="hinge"
                                   axis="0 1 0"
                                   range="0 2.0"/>

                            <geom type="cylinder"
                                  size="0.04 0.05"
                                  quat="0.7071 0.7071 0 0"
                                  mass="0.2"
                                  rgba="1 0.5 0 1"/>

                            <geom name="right_shin"
                                  type="capsule"
                                  fromto="0 0 0 0 0 -0.40"
                                  size="0.04"
                                  mass="3"
                                  rgba="0.9 0.55 0.15 1"/>

                            <body name="right_ankle_pitch_link"
                                  pos="0 0 -0.40">

                                <joint name="right_ankle_pitch"
                                       type="hinge"
                                       axis="0 1 0"
                                       range="-0.8 0.6"/>

                                <geom type="cylinder"
                                      size="0.03 0.04"
                                      quat="0.7071 0.7071 0 0"
                                      mass="0.2"
                                      rgba="1 1 0 1"/>

                                <body name="right_foot_link"
                                      pos="0 0 -0.05">

                                    <joint name="right_ankle_roll"
                                           type="hinge"
                                           axis="1 0 0"
                                           range="-0.35 0.35"/>

                                    <geom type="cylinder"
                                          size="0.03 0.04"
                                          quat="0.7071 0 0.7071 0"
                                          mass="0.2"
                                          rgba="1 0 1 1"/>

                                    <geom name="right_foot"
                                          type="box"
                                          size="0.18 0.09 0.025"
                                          pos="0.06 0 -0.025"
                                          mass="1.5"
                                          rgba="0.2 0.8 0.2 1"/>

                                </body>
                            </body>
                        </body>
                    </body>
                </body>
            </body>

        </body>
    </worldbody>

    <actuator>
        <motor joint="left_hip_yaw" gear="100"/>
        <motor joint="left_hip_roll" gear="150"/>
        <motor joint="left_hip_pitch" gear="300"/>
        <motor joint="left_knee_pitch" gear="350"/>
        <motor joint="left_ankle_pitch" gear="200"/>
        <motor joint="left_ankle_roll" gear="100"/>

        <motor joint="right_hip_yaw" gear="100"/>
        <motor joint="right_hip_roll" gear="150"/>
        <motor joint="right_hip_pitch" gear="300"/>
        <motor joint="right_knee_pitch" gear="350"/>
        <motor joint="right_ankle_pitch" gear="200"/>
        <motor joint="right_ankle_roll" gear="100"/>
    </actuator>

</mujoco>